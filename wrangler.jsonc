{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "aggregation-arena-api",
  "main": "src/index.js",
  "compatibility_date": "2026-07-01",
  "observability": { "enabled": true },
  "triggers": { "crons": ["*/5 * * * *"] },
  "vars": {
    "ALLOWED_ORIGIN": "https://chengpeng9660.github.io",
    "MAX_ACTIVE_MARKETS": "20"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "aggregation-arena-db",
      "database_id": "01c1e3e3-ac52-4b39-bf45-8abcb7c64bf1"
    }
  ]
}
